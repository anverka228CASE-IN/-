#  БЛОК 4: АНАЛИЗ И КЛАСТЕРИЗАЦИЯ (Scikit-Learn)
# ─────────────────────────────────────────────────────────────
class PatentClusterer:
    """Кластеризация патентов методами KMeans и DBSCAN."""

    CLUSTER_LABELS = {
        0: "Суспензионная полимеризация",
        1: "Эмульсионная полимеризация",
        2: "Высокотемпературные процессы (>120°C)",
        3: "Растворная полимеризация (RAFT/ATRP)",
        4: "Сшивание эластомеров",
        5: "Фотоинициированная полимеризация",
    }

    def __init__(self, n_clusters: int = 6):
        self.n_clusters = n_clusters
        self.vectorizer = TfidfVectorizer(
            max_features=500,
            stop_words="english",
            ngram_range=(1, 2),
            min_df=1,
        )
        self.scaler = StandardScaler()

    def prepare_features(self, df: pd.DataFrame) -> np.ndarray:
        """Подготавливает признаки для кластеризации."""
        # TF-IDF из текстов
        texts = (df["title"].fillna("") + " " + df["abstract"].fillna("")).tolist()
        tfidf_matrix = self.vectorizer.fit_transform(texts).toarray()
        
        # Числовые признаки
        numeric_cols = ["temperature_C", "pressure_atm", "concentration_wt", 
                       "Mn", "Mw", "PDI", "yield_pct"]
        numeric_data = df[numeric_cols].fillna(df[numeric_cols].median()).values
        numeric_scaled = self.scaler.fit_transform(numeric_data)
        
        # Объединяем TF-IDF (80% веса) + числовые (20% веса)
        combined = np.hstack([tfidf_matrix * 0.8, numeric_scaled * 0.2])
        return combined

    def cluster_kmeans(self, features: np.ndarray) -> np.ndarray:
        """KMeans кластеризация."""
        kmeans = KMeans(n_clusters=self.n_clusters, random_state=42, n_init=20, max_iter=500)
        labels = kmeans.fit_predict(features)
        score = silhouette_score(features, labels)
        console.print(f"[green]✅ KMeans: {self.n_clusters} кластеров, Silhouette={score:.3f}[/green]")
        return labels

    def cluster_dbscan(self, features: np.ndarray) -> np.ndarray:
        """DBSCAN кластеризация (автоматическое определение числа кластеров)."""
        # Снижаем размерность для DBSCAN
        pca = PCA(n_components=20, random_state=42)
        features_pca = pca.fit_transform(features)
        
        dbscan = DBSCAN(eps=1.5, min_samples=2, metric="euclidean")
        labels = dbscan.fit_predict(features_pca)
        n_clusters = len(set(labels)) - (1 if -1 in labels else 0)
        console.print(f"[green]✅ DBSCAN: {n_clusters} кластеров автоматически[/green]")
        return labels

    def reduce_dimensions(self, features: np.ndarray) -> tuple:
        """Снижение размерности PCA + t-SNE для визуализации."""
        # PCA → 50 компонент
        n_comp = min(50, features.shape[0] - 1, features.shape[1])
        pca = PCA(n_components=n_comp, random_state=42)
        pca_result = pca.fit_transform(features)
        
        # t-SNE → 2D
        perplexity = min(30, max(5, len(features) // 3))
        tsne = TSNE(n_components=2, random_state=42, perplexity=perplexity,
                   n_iter=1000, learning_rate="auto", init="pca")
        tsne_result = tsne.fit_transform(pca_result)
        
        return pca_result, tsne_result

    def analyze(self, df: pd.DataFrame) -> pd.DataFrame:
        """Полный анализ и кластеризация."""
        console.print("[cyan]🤖 Запуск кластеризации (Scikit-Learn)...[/cyan]")
        
        features = self.prepare_features(df)
        
        km_labels = self.cluster_kmeans(features)
        db_labels = self.cluster_dbscan(features)
        pca_result, tsne_result = self.reduce_dimensions(features)
        
        df = df.copy()
        df["cluster_kmeans"] = km_labels
        df["cluster_dbscan"] = db_labels
        df["cluster_label"] = df["cluster_kmeans"].map(
            lambda x: self.CLUSTER_LABELS.get(x, f"Кластер {x}")
        )
        df["tsne_x"] = tsne_result[:, 0]
        df["tsne_y"] = tsne_result[:, 1]
        df["pca_x"] = pca_result[:, 0]
        df["pca_y"] = pca_result[:, 1]
        
        path = os.path.join(CONFIG["output_dir"], CONFIG["clusters_csv"])
        df.to_csv(path, index=False, encoding="utf-8-sig")
        console.print(f"[green]✅ Кластеризация сохранена → {path}[/green]")
        return df


