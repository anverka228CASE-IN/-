    def plot_tsne_clusters(self, df: pd.DataFrame):
        """Интерактивная t-SNE карта кластеров (Plotly)."""
        fig = px.scatter(
            df, x="tsne_x", y="tsne_y",
            color="cluster_label",
            hover_data=["patent_id", "title", "assignee", "temperature_C",
                        "monomer", "yield_pct", "PDI"],
            title="🗺 t-SNE карта патентных кластеров: Пероксидные инициаторы",
