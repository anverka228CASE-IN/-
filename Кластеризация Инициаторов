class PatentAnalysisPipeline:
    """Главный класс — запускает весь пайплайн одной командой."""

    def __init__(self):
        self.collector = PatentCollector(CONFIG["query"], CONFIG["max_patents"])
        self.extractor = ChemicalExtractor()
        self.unifier = ChemUnifier()
        self.clusterer = PatentClusterer(CONFIG["n_clusters"])
        self.visualizer = Visualizer(CONFIG["output_dir"])

    def run(self):
        """🚀 Запуск полного пайплайна."""
        console.print(Panel.fit(
            "🔬 ПАТЕНТНЫЙ АНАЛИЗАТОР\n"
            "Пероксидные инициаторы радикальной полимеризации\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
            "WIPO → ChemDataExtractor → PubChem/RDKit → Scikit-Learn → Gephi",
            style="bold green",
        ))
        
        start_time = datetime.now()
        
        # ── Шаг 1: Сбор патентов ──
        console.print("\n[bold cyan]═══ ШАГ 1: СБОР ПАТЕНТНЫХ ДАННЫХ ═══[/bold cyan]")
        df = self.collector.collect()
        console.print(f"   Получено: {len(df)} патентов\n")
        
        # ── Шаг 2: Извлечение данных ──
        console.print("[bold cyan]═══ ШАГ 2: ИЗВЛЕЧЕНИЕ ХИМИЧЕСКИХ ДАННЫХ ═══[/bold cyan]")
        df = self.extractor.enrich_dataframe(df)
        console.print("")
        
        # ── Шаг 3: Унификация ──
        console.print("[bold cyan]═══ ШАГ 3: УНИФИКАЦИЯ (PubChem + RDKit) ═══[/bold cyan]")
        df, compounds_df = self.unifier.unify_peroxides_in_df(df)
        console.print("")
        
        # ── Шаг 4: Кластеризация ──
        console.print("[bold cyan]═══ ШАГ 4: АНАЛИЗ И КЛАСТЕРИЗАЦИЯ ═══[/bold cyan]")
        df = self.clusterer.analyze(df)
        console.print("")
        
        # ── Шаг 5: Визуализация ──
        console.print("[bold cyan]═══ ШАГ 5: ВИЗУАЛИЗАЦИЯ ═══[/bold cyan]")
        self.visualizer.plot_tsne_clusters(df)
        self.visualizer.plot_process_conditions(df)
        self.visualizer.plot_peroxide_usage(df)
        self.visualizer.plot_interactive_dashboard(df)
        self.visualizer.build_gephi_graph(df)
        self.visualizer.print_cluster_report(df)
        
        # ── Финальный отчёт ──
        elapsed = (datetime.now() - start_time).seconds
        console.print(Panel.fit(
            f"[bold green]✅ ПАЙПЛАЙН ЗАВЕРШЁН за {elapsed} сек.[/bold green]\n\n"
            f"📁 Все файлы сохранены в: [cyan]{CONFIG['output_dir']}/[/cyan]\n\n"
            f"📄 [white]patents_full.csv[/white]         — все патенты с параметрами\n"
            f"📄 [white]patent_clusters.csv[/white]     — патенты с кластерами\n"
            f"📄 [white]unified_compounds.csv[/white]   — унифицированные соединения\n"
            f"🌐 [white]tsne_clusters.html[/white]      — интерактивная t-SNE карта\n"
            f"🌐 [white]full_dashboard.html[/white]     — аналитический дашборд\n"
            f"🖼 [white]process_conditions.png[/white]  — условия процессов\n"
            f"🖼 [white]peroxide_usage.png[/white]      — статистика инициаторов\n"
            f"🖼 [white]patent_graph_preview.png[/white]— граф связей (превью)\n"
            f"📊 [white]patent_graph.graphml[/white]    — граф для Gephi",
            style="bold green",
        ))
        
        return df, compounds_df


