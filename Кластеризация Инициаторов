class ChemUnifier:
    """Нормализация химических названий через PubChem и генерация дескрипторов через RDKit."""

    PEROXIDE_SMILES = {
        "benzoyl peroxide":        "O=C(OOC(=O)c1ccccc1)c1ccccc1",
        "dicumyl peroxide":        "CC(C)(OOC(C)(C)c1ccccc1)c1ccccc1",
        "lauroyl peroxide":        "O=C(CCCCCCCCCCCC)OOC(=O)CCCCCCCCCCCC",
        "tert-butyl peroxide":     "CC(C)(C)OOC(C)(C)C",
        "di-tert-butyl peroxide":  "CC(C)(C)OOC(C)(C)C",
        "cumene hydroperoxide":    "CC(C)(OO)c1ccccc1",
        "tert-butyl hydroperoxide":"CC(C)(C)OO",
        "hydrogen peroxide":       "OO",
        "AIBN":                    "N#CC(C)(C)/N=N/C(C)(C)C#N",
        "azobisisobutyronitrile":  "N#CC(C)(C)/N=N/C(C)(C)C#N",
        "potassium persulfate":    "[K+].[K+].[O-]S(=O)(=O)OOS(=O)(=O)[O-]",
        "ammonium persulfate":     "[NH4+].[NH4+].[O-]S(=O)(=O)OOS(=O)(=O)[O-]",
        "peracetic acid":          "CC(=O)OO",
        "methyl ethyl ketone peroxide": "CCC(C)(OO)OOC(C)(CC)OO",
    }

    def __init__(self):
        self.unified_cache = {}
        self.descriptors_cache = {}
        self._init_rdkit()

    def _init_rdkit(self):
        try:
            from rdkit import Chem
            from rdkit.Chem import Descriptors, rdMolDescriptors, Draw
            self.Chem = Chem
            self.Descriptors = Descriptors
            self.rdMolDescriptors = rdMolDescriptors
            self.rdkit_available = True
            console.print("[green]✅ RDKit загружен[/green]")
        except ImportError:
            self.rdkit_available = False
            console.print("[yellow]⚠ RDKit не установлен. Используются базовые дескрипторы.[/yellow]")

    def get_pubchem_data(self, compound_name: str) -> dict:
        """Получает данные из PubChem по названию соединения."""
        if compound_name in self.unified_cache:
            return self.unified_cache[compound_name]
        
        url = f"https://pubchem.ncbi.nlm.nih.gov/rest/pug/compound/name/{requests.utils.quote(compound_name)}/JSON"
        try:
            resp = requests.get(url, timeout=10)
            if resp.status_code == 200:
                data = resp.json()
                props = data["PC_Compounds"][0].get("props", [])
                result = {"name": compound_name, "cid": data["PC_Compounds"][0]["id"]["id"]["cid"]}
                for prop in props:
                    urn = prop.get("urn", {})
                    label = urn.get("label", "")
                    val = prop.get("value", {})
                    if label == "IUPAC Name" and urn.get("name") == "Preferred":
                        result["iupac_name"] = val.get("sval", "")
                    elif label == "Molecular Formula":
                        result["formula"] = val.get("sval", "")
                    elif label == "Molecular Weight":
                        result["mol_weight"] = val.get("fval", val.get("sval", ""))
                    elif label == "SMILES" and urn.get("name") == "Canonical":
                        result["smiles"] = val.get("sval", "")
                self.unified_cache[compound_name] = result
                time.sleep(0.2)
                return result
        except Exception:
            pass
        
        # Fallback: используем локальный словарь SMILES
        fallback = {"name": compound_name, "smiles": self.PEROXIDE_SMILES.get(compound_name.lower(), "")}
        self.unified_cache[compound_name] = fallback
        return fallback

    def compute_rdkit_descriptors(self, smiles: str) -> dict:
        """Вычисляет молекулярные дескрипторы через RDKit."""
        if not self.rdkit_available or not smiles:
            return {}
        
        if smiles in self.descriptors_cache:
            return self.descriptors_cache[smiles]
        
        try:
            mol = self.Chem.MolFromSmiles(smiles)
            if mol is None:
                return {}
            
            desc = {
                "MW": self.Descriptors.MolWt(mol),
                "LogP": self.Descriptors.MolLogP(mol),
                "TPSA": self.Descriptors.TPSA(mol),
                "HBD": self.rdMolDescriptors.CalcNumHBD(mol),
                "HBA": self.rdMolDescriptors.CalcNumHBA(mol),
                "RotBonds": self.rdMolDescriptors.CalcNumRotatableBonds(mol),
                "Rings": self.rdMolDescriptors.CalcNumRings(mol),
                "ArRings": self.rdMolDescriptors.CalcNumAromaticRings(mol),
                "NumAtoms": mol.GetNumHeavyAtoms(),
            }
            self.descriptors_cache[smiles] = desc
            return desc
        except Exception:
            return {}

    def unify_peroxides_in_df(self, df: pd.DataFrame) -> tuple:
        """Унифицирует все пероксиды в датафрейме и строит таблицу соединений."""
        console.print("[cyan]🔗 Унификация названий через PubChem + RDKit...[/cyan]")
        
        all_peroxides = set()
        for _, row in df.iterrows():
            try:
                peroxides = json.loads(str(row.get("peroxides", "[]")))
                all_peroxides.update([p.lower() for p in peroxides])
            except Exception:
                pass
        
        compounds_data = []
        for peroxide in tqdm(list(all_peroxides), desc="PubChem запросы"):
            pub_data = self.get_pubchem_data(peroxide)
            smiles = pub_data.get("smiles", self.PEROXIDE_SMILES.get(peroxide, ""))
            rdkit_desc = self.compute_rdkit_descriptors(smiles)
            
            compound_info = {
                "name": peroxide,
                "cid": pub_data.get("cid", "N/A"),
                "iupac_name": pub_data.get("iupac_name", ""),
                "formula": pub_data.get("formula", ""),
                "mol_weight": pub_data.get("mol_weight", rdkit_desc.get("MW", "")),
                "smiles": smiles,
                **rdkit_desc,
            }
            compounds_data.append(compound_info)
        
        compounds_df = pd.DataFrame(compounds_data)
        path = os.path.join(CONFIG["output_dir"], "unified_compounds.csv")
        compounds_df.to_csv(path, index=False, encoding="utf-8-sig")
        console.print(f"[green]✅ Унифицировано {len(compounds_df)} соединений → {path}[/green]")
        return df, compounds_df


