    def plot_peroxide_usage(self, df: pd.DataFrame):
        """Статистика использования пероксидных инициаторов."""
        peroxide_count = {}
        for _, row in df.iterrows():
            try:
                peroxides = json.loads(str(row.get("peroxides", "[]")))
                for p in peroxides:
                    peroxide_count[p] = peroxide_count.get(p, 0) + 1
            except Exception:
                pass
        
        if not peroxide_count:
            return
        
        sorted_peroxides = sorted(peroxide_count.items(), key=lambda x: x[1], reverse=True)
        names, counts = zip(*sorted_peroxides[:15])
        
        fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 7))
        fig.suptitle("Анализ пероксидных инициаторов в патентах", fontsize=14, fontweight="bold")
        
        # Bar chart
        bars = ax1.barh(list(names)[::-1], list(counts)[::-1],
                       color=self.COLORS[:len(names)], edgecolor="white", linewidth=0.5)
        ax1.set_xlabel("Количество патентов", fontsize=11)
        ax1.set_title("Частота использования инициаторов", fontsize=12)
        ax1.grid(True, alpha=0.3, axis="x")
        for bar, count in zip(bars, list(counts)[::-1]):
            ax1.text(bar.get_width() + 0.1, bar.get_y() + bar.get_height()/2,
                    str(count), va="center", fontsize=9)
        
        # Pie chart
        ax2.pie(counts[:8], labels=[n[:25] for n in names[:8]],
               autopct="%1.1f%%", colors=self.COLORS[:8],
               startangle=90, pctdistance=0.8)
        ax2.set_title("Доля в патентном портфеле", fontsize=12)
        
        plt.tight_layout()
        path = os.path.join(self.output_dir, "peroxide_usage.png")
        plt.savefig(path, dpi=150, bbox_inches="tight")
        plt.close()
        console.print(f"[green]✅ Анализ пероксидов → {path}[/green]")

