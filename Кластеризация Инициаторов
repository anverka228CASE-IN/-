#  БЛОК 2: ИЗВЛЕЧЕНИЕ ДАННЫХ (ChemDataExtractor + LLM-like NLP)
# ─────────────────────────────────────────────────────────────
class ChemicalExtractor:
    """Извлечение химических данных и параметров реакций из текстов патентов."""

    def __init__(self):
        self.peroxide_pattern = re.compile(
            r'\b(' + '|'.join(re.escape(k) for k in PEROXIDE_KEYWORDS) + r')\b',
            re.IGNORECASE
        )
        self.temp_pattern = re.compile(
            r'(\d+(?:\.\d+)?)\s*(?:°C|°F|K|degrees?\s+(?:Celsius|centigrade|Fahrenheit|Kelvin))',
            re.IGNORECASE
        )
        self.pressure_pattern = re.compile(
            r'(\d+(?:\.\d+)?)\s*(?:atm|bar|MPa|kPa|psi|Pa)',
            re.IGNORECASE
        )
        self.mw_pattern = re.compile(
            r'(?:Mn|Mw|molecular weight|mol\.?\s*wt\.?)\s*[=:≈~]\s*(\d+(?:[,.]?\d+)?)\s*(?:g/?mol|Da|kDa)?',
            re.IGNORECASE
        )
        self.pdi_pattern = re.compile(
            r'(?:PDI|Mw/Mn|dispersity|Ð)\s*[=:≈~]\s*(\d+(?:\.\d+)?)',
            re.IGNORECASE
        )
        self.yield_pattern = re.compile(
            r'(?:conversion|yield|conversion rate)\s*[=>:≈~]\s*(\d+(?:\.\d+)?)\s*%',
            re.IGNORECASE
        )
        self.conc_pattern = re.compile(
            r'(\d+(?:\.\d+)?)\s*(?:wt\.?%|mol%|phr|%\s*w/w|%\s*by\s*weight)',
            re.IGNORECASE
        )

    def extract_from_text(self, text: str) -> dict:
        """Извлекает все параметры из текста патента."""
        result = {
            "found_peroxides": [],
            "temperatures": [],
            "pressures": [],
            "molecular_weights": [],
            "pdi_values": [],
            "yields": [],
            "concentrations": [],
        }
        
        if not text or not isinstance(text, str):
            return result
        
        result["found_peroxides"] = list(set(
            m.group(0).lower() for m in self.peroxide_pattern.finditer(text)
        ))
        result["temperatures"] = [float(m.group(1)) for m in self.temp_pattern.finditer(text)]
        result["pressures"] = [float(m.group(1)) for m in self.pressure_pattern.finditer(text)]
        result["molecular_weights"] = [
            float(m.group(1).replace(",", "")) for m in self.mw_pattern.finditer(text)
        ]
        result["pdi_values"] = [float(m.group(1)) for m in self.pdi_pattern.finditer(text)]
        result["yields"] = [float(m.group(1)) for m in self.yield_pattern.finditer(text)]
        result["concentrations"] = [float(m.group(1)) for m in self.conc_pattern.finditer(text)]
        
        return result

    def enrich_dataframe(self, df: pd.DataFrame) -> pd.DataFrame:
        """Обогащает датафрейм извлечёнными данными."""
        console.print("[cyan]🔬 Извлечение химических данных из текстов патентов...[/cyan]")
        
        extracted_rows = []
        for _, row in tqdm(df.iterrows(), total=len(df), desc="Обработка патентов"):
            text = f"{row.get('title', '')} {row.get('abstract', '')}"
            ext = self.extract_from_text(text)
            
            row_dict = row.to_dict()
            row_dict["extracted_peroxides"] = json.dumps(ext["found_peroxides"], ensure_ascii=False)
            row_dict["extracted_temp_min"] = min(ext["temperatures"]) if ext["temperatures"] else np.nan
            row_dict["extracted_temp_max"] = max(ext["temperatures"]) if ext["temperatures"] else np.nan
            row_dict["extracted_pressure"] = max(ext["pressures"]) if ext["pressures"] else np.nan
            row_dict["extracted_Mn"] = min(ext["molecular_weights"]) if ext["molecular_weights"] else np.nan
            row_dict["extracted_PDI"] = np.mean(ext["pdi_values"]) if ext["pdi_values"] else np.nan
            row_dict["extracted_yield"] = max(ext["yields"]) if ext["yields"] else np.nan
            row_dict["extracted_conc"] = min(ext["concentrations"]) if ext["concentrations"] else np.nan
            
            extracted_rows.append(row_dict)
        
        enriched_df = pd.DataFrame(extracted_rows)
        console.print(f"[green]✅ Извлечение завершено для {len(enriched_df)} патентов[/green]")
        return enriched_df


