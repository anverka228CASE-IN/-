    def fetch_from_epo_ops(self) -> list:
        """
        Использует EPO Open Patent Services (OPS) — бесплатный API.
        Endpoint: https://ops.epo.org/3.2/rest-services/
        Для патентного поиска используем CQL-запрос.
        """
        console.print("[cyan]📡 Подключение к EPO Open Patent Services...[/cyan]")
        base_url = "https://ops.epo.org/3.2/rest-services/published-data/search"
        
        # Формируем CQL-запрос для пероксидных инициаторов
        cql_query = (
            'txt="peroxide initiator" AND txt="radical polymerization"'
            ' OR txt="organic peroxide" AND txt="polymerization initiator"'
        )
        
        headers = {
            "Accept": "application/json",
            "Content-Type": "application/x-www-form-urlencoded",
        }
        
        patents = []
        batch_size = 25
        
        for start in range(1, min(self.max_results, 100) + 1, batch_size):
            params = {
                "q": cql_query,
                "Range": f"{start}-{min(start + batch_size - 1, self.max_results)}",
            }
            try:
                resp = requests.get(base_url, params=params, headers=headers, timeout=30)
                if resp.status_code == 200:
                    data = resp.json()
                    docs = (
                        data.get("ops:world-patent-data", {})
                            .get("ops:biblio-search", {})
                            .get("ops:search-result", {})
                            .get("ops:publication-reference", [])
                    )
                    if isinstance(docs, dict):
                        docs = [docs]
                    for doc in docs:
                        doc_id = doc.get("@document-id-type", "")
                        patents.append({
                            "patent_id": str(doc.get("ops:document-id", {}).get("doc-number", {}).get("$", "")),
                            "title": "EPO Patent",
                            "abstract": "",
                            "source": "EPO OPS",
                        })
                elif resp.status_code == 403:
                    console.print("[yellow]⚠ EPO OPS требует регистрацию. Переключаемся на fallback...[/yellow]")
                    break
            except Exception as e:
                console.print(f"[yellow]⚠ EPO OPS недоступен: {e}[/yellow]")
                break
            time.sleep(1)
        
        return patents

    def fetch_from_google_patents_scraper(self) -> list:
        """
        Получаем данные с Google Patents через публичный поисковый endpoint.
        Используем scraping с корректными заголовками.
        """
        console.print("[cyan]📡 Получение патентов с Google Patents...[/cyan]")
        patents = []
        
        search_terms = [
            "peroxide+initiator+radical+polymerization",
            "organic+peroxide+polymer+initiator",
            "benzoyl+peroxide+polymerization",
            "dicumyl+peroxide+radical+initiator",
        ]
        
        headers = {
            "User-Agent": (
                "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
                "AppleWebKit/537.36 (KHTML, like Gecko) "
                "Chrome/120.0.0.0 Safari/537.36"
            )
        }
        
        for term in search_terms[:2]:  # Ограничиваем для скорости
            url = f"https://patents.google.com/xhr/query?url=q%3D{term}&exp=&tags="
            try:
                resp = requests.get(url, headers=headers, timeout=20)
                if resp.status_code == 200:
                    data = resp.json()
                    results = data.get("results", {}).get("cluster", [])
                    for cluster in results:
                        for patent_data in cluster.get("result", []):
                            p = patent_data.get("patent", {})
                            patents.append({
                                "patent_id": p.get("publication_number", "N/A"),
                                "title": p.get("title", "N/A"),
                                "abstract": p.get("abstract", ""),
                                "assignee": ", ".join(p.get("assignee", [])),
                                "inventor": ", ".join(p.get("inventor", [])),
                                "filing_date": p.get("filing_date", ""),
                                "publication_date": p.get("publication_date", ""),
                                "cpc_codes": ", ".join(p.get("cpc", [])),
                                "source": "Google Patents",
                            })
                            if len(patents) >= self.max_results:
                                break
            except Exception as e:
                console.print(f"[yellow]⚠ Google Patents: {e}[/yellow]")
            time.sleep(1.5)
        
        return patents

