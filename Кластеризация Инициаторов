    def build_gephi_graph(self, df: pd.DataFrame):
        """Строит граф связей патентов для Gephi (GraphML формат)."""
        console.print("[cyan]🕸 Построение графа для Gephi...[/cyan]")
        
        G = nx.Graph()
        
        # Узлы — патенты
        for _, row in df.iterrows():
            G.add_node(
                row["patent_id"],
                label=str(row.get("title", ""))[:50],
                cluster=int(row.get("cluster_kmeans", 0)),
                cluster_name=str(row.get("cluster_label", "")),
                assignee=str(row.get("assignee", "")),
                temperature=float(row.get("temperature_C", 0) or 0),
                monomer=str(row.get("monomer", "")),
                yield_pct=float(row.get("yield_pct", 0) or 0),
                Mn=float(row.get("Mn", 0) or 0),
                PDI=float(row.get("PDI", 0) or 0),
            )
        
        # Рёбра — связи между патентами одного кластера
        patents_list = df["patent_id"].tolist()
        for i in range(len(df)):
            for j in range(i + 1, len(df)):
                row_i = df.iloc[i]
                row_j = df.iloc[j]
                
                weight = 0.0
                # Связь по кластеру
                if row_i["cluster_kmeans"] == row_j["cluster_kmeans"]:
                    weight += 3.0
                # Связь по мономеру
                if (str(row_i.get("monomer", "")) == str(row_j.get("monomer", ""))
                        and row_i.get("monomer")):
                    weight += 2.0
                # Связь по пероксиду
                try:
                    p_i = set(json.loads(str(row_i.get("peroxides", "[]"))))
                    p_j = set(json.loads(str(row_j.get("peroxides", "[]"))))
                    if p_i & p_j:
                        weight += 1.5
                except Exception:
                    pass
                # Связь по температуре (±20°C)
                t_i = row_i.get("temperature_C", 0) or 0
                t_j = row_j.get("temperature_C", 0) or 0
                if abs(float(t_i) - float(t_j)) <= 20:
                    weight += 0.5
                
                if weight >= 3.0:  # Добавляем только значимые связи
                    G.add_edge(patents_list[i], patents_list[j], weight=round(weight, 2))
        
        # Сохраняем GraphML для Gephi
        graphml_path = os.path.join(self.output_dir, CONFIG["gephi_file"])
        nx.write_graphml(G, graphml_path)
        console.print(f"[green]✅ Граф для Gephi → {graphml_path} ({G.number_of_nodes()} узлов, {G.number_of_edges()} рёбер)[/green]")
        
        # Визуализация через NetworkX (превью)
        fig, ax = plt.subplots(figsize=(16, 12))
        fig.patch.set_facecolor("#1a1a2e")
        ax.set_facecolor("#1a1a2e")
        
        clusters = nx.get_node_attributes(G, "cluster")
        node_colors = [self.COLORS[clusters.get(n, 0) % len(self.COLORS)] for n in G.nodes()]
        node_sizes = [200 + G.degree(n) * 50 for n in G.nodes()]
        
        pos = nx.spring_layout(G, k=2.5, seed=42, weight="weight")
        
        edges_weights = [G[u][v]["weight"] for u, v in G.edges()]
        max_w = max(edges_weights) if edges_weights else 1
        
        nx.draw_networkx_edges(G, pos, ax=ax, alpha=0.3,
                              width=[w / max_w * 2 for w in edges_weights],
                              edge_color="white")
        nx.draw_networkx_nodes(G, pos, ax=ax, node_color=node_colors,
                              node_size=node_sizes, alpha=0.9)
        nx.draw_networkx_labels(G, pos, ax=ax,
                               labels={n: n.split("_")[0][:12] for n in G.nodes()},
                               font_size=6, font_color="white")
        
        # Легенда кластеров
        legend_patches = [
            mpatches.Patch(color=self.COLORS[i], label=PatentClusterer.CLUSTER_LABELS.get(i, f"Кластер {i}"))
            for i in range(CONFIG["n_clusters"])
        ]
        ax.legend(handles=legend_patches, loc="upper left", fontsize=8,
                 facecolor="#1a1a2e", labelcolor="white", edgecolor="gray")
        ax.set_title("Граф связей патентов (превью для Gephi)",
                    color="white", fontsize=14, fontweight="bold")
        ax.axis("off")
        
        preview_path = os.path.join(self.output_dir, "patent_graph_preview.png")
        plt.savefig(preview_path, dpi=150, bbox_inches="tight", facecolor="#1a1a2e")
        plt.close()
        console.print(f"[green]✅ Превью графа → {preview_path}[/green]")

    def print_cluster_report(self, df: pd.DataFrame):
        """Выводит детальный отчёт по кластерам в консоль."""
        console.print("\n")
        console.print(Panel.fit(
            "📊 ОТЧЁТ ПО ТЕХНОЛОГИЧЕСКИМ КЛАСТЕРАМ\nПероксидные инициаторы радикальной полимеризации",
            style="bold cyan",
        ))
        
        for cluster_id in sorted(df["cluster_kmeans"].unique()):
            subset = df[df["cluster_kmeans"] == cluster_id]
            label = PatentClusterer.CLUSTER_LABELS.get(cluster_id, f"Кластер {cluster_id}")
            
            table = Table(
                title=f"[bold yellow]Кластер {cluster_id}: {label}[/bold yellow] ({len(subset)} патентов)",
                show_header=True, header_style="bold magenta",
                border_style="dim",
            )
            table.add_column("Параметр", style="cyan", width=28)
            table.add_column("Среднее", justify="right", width=15)
            table.add_column("Мин", justify="right", width=12)
            table.add_column("Макс", justify="right", width=12)
            
            params_map = [
                ("temperature_C", "Температура, °C"),
                ("pressure_atm", "Давление, атм"),
                ("concentration_wt", "Конц. инициатора, wt%"),
                ("Mn", "Mn, г/моль"),
                ("PDI", "PDI"),
                ("yield_pct", "Конверсия, %"),
            ]
            
            for col, name in params_map:
                vals = subset[col].dropna()
                if len(vals) > 0:
                    table.add_row(
                        name,
                        f"{vals.mean():.2f}",
                        f"{vals.min():.2f}",
                        f"{vals.max():.2f}",
                    )
            
            console.print(table)
            
            # Топ пероксиды кластера
            peroxide_freq = {}
            for _, row in subset.iterrows():
                try:
                    for p in json.loads(str(row.get("peroxides", "[]"))):
                        peroxide_freq[p] = peroxide_freq.get(p, 0) + 1
                except Exception:
                    pass
            
            if peroxide_freq:
                top_peroxides = sorted(peroxide_freq.items(), key=lambda x: x[1], reverse=True)[:3]
                console.print(
                    f"  [green]Инициаторы:[/green] " +
                    ", ".join(f"{p} ({c})" for p, c in top_peroxides)
                )
            
            # Топ мономеры
            monomers = subset["monomer"].dropna().value_counts().head(3)
            if not monomers.empty:
                console.print(
                    f"  [green]Мономеры:[/green] " +
                    ", ".join(f"{m} ({c})" for m, c in monomers.items())
                )
            console.print("")


